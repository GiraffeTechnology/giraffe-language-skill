GIRAFFE_LANGUAGE_SKILL_HOST=127.0.0.1
GIRAFFE_LANGUAGE_SKILL_PORT=8788
GIRAFFE_LANGUAGE_CANONICAL_LANGUAGE=en

GIRAFFE_TRANSLATION_PROVIDER=mock
GIRAFFE_TRANSLATION_MODEL_DIR=./models
GIRAFFE_TRANSLATION_DEVICE=cpu
GIRAFFE_TRANSLATION_COMPUTE_TYPE=int8
GIRAFFE_TRANSLATION_CACHE_ENABLED=true

GIRAFFE_GLOSSARY_PATH=src/giraffe_language_skill/glossary/giraffe_trade_glossary.yml
GIRAFFE_REQUIRE_CRITICAL_FIELDS=true
GIRAFFE_DEFAULT_TARGET_LANGUAGE=en
